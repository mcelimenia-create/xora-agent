TELEGRAM_TOKEN=
ANTHROPIC_API_KEY=
BRAVE_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=XORA <contacto@xoralab.com>
REPLY_TO_EMAIL=contacto@xoralab.com
SITE_URL=https://xoralab.com
REDIS_URL=
ALLOWED_USER_ID=

# Opcional — activa mensajes de voz con Whisper
OPENAI_API_KEY=

# Seguimiento automático: si es "true", envía el email solo sin avisarte
AUTO_FOLLOWUP=false
# Días sin respuesta antes de hacer seguimiento (por defecto 5)
AUTO_FOLLOWUP_DAYS=5

# Puerto para el servidor webhook de Resend (Railway lo pone automáticamente)
PORT=3000
